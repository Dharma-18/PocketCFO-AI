<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F8FAFC">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_premium_gradient" android:paddingHorizontal="20dp"
            android:paddingTop="44dp" android:paddingBottom="16dp" android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="🤖 AI Tips" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold"/>
            <ImageButton android:id="@+id/btnExportInsights" android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_stat_blue" android:src="@android:drawable/ic_menu_save"
                android:contentDescription="Export PDF"/>
        </LinearLayout>

        <!-- 7-Day Trend Chart -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:text="7-Day Activity Trend"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">
            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/insightsLineChart"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="12dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Spending Pattern Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_bot_bubble_pro"
            android:layout_marginHorizontal="16dp" android:layout_marginTop="16dp" android:padding="16dp"
            android:elevation="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📈 Where Money Goes" android:textColor="#000000" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvSpendingInsight" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Log entries to see where money goes..." android:textColor="#000000"
                android:textSize="13sp" android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Income Trend Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_bot_bubble_pro"
            android:layout_marginHorizontal="16dp" android:layout_marginTop="12dp" android:padding="16dp"
            android:elevation="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💰 Money Coming In" android:textColor="#000000" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvIncomeInsight" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Your earning trends will appear here..." android:textColor="#000000"
                android:textSize="13sp" android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Cash Flow Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_bot_bubble_pro"
            android:layout_marginHorizontal="16dp" android:layout_marginTop="12dp" android:padding="16dp"
            android:elevation="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔄 Cash vs Online" android:textColor="#000000" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvCashFlowInsight" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Cash vs UPI breakdown will appear here..." android:textColor="#000000"
                android:textSize="13sp" android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Category Breakdown Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_bot_bubble_pro"
            android:layout_marginHorizontal="16dp" android:layout_marginTop="12dp" android:padding="16dp"
            android:elevation="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📂 By Category" android:textColor="#000000" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvCategoryInsight" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Category analysis will appear here..." android:textColor="#000000"
                android:textSize="13sp" android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- AI Suggestions -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_insight_bubble"
            android:layout_marginHorizontal="16dp" android:layout_marginTop="12dp" android:padding="16dp"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💡 AI Advice" android:textColor="#0D9488" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvAiSuggestion" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Keep logging daily to unlock smarter tips!" android:textColor="#0D9488"
                android:textSize="13sp" android:layout_marginTop="8dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

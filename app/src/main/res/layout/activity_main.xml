<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light_gray">

    <!-- 1. PARALLAX HEADER -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:background="@android:color/transparent"
        android:fitsSystemWindows="true"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="true"
            app:contentScrim="@color/primary_indigo"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap">

            <!-- Parallax Background -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_premium_gradient"
                android:scaleType="centerCrop"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.7" />
                
            <!-- Abstract shapes (optional) for depth -->
            <View
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-40dp"
                android:layout_marginEnd="-40dp"
                android:alpha="0.1"
                android:background="@drawable/bg_user_bubble"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.9" />

            <!-- Dashboard Content inside Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="30dp"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.5">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wallet Balance"
                    android:textColor="#94A3B8"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvProfit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 0"
                    android:textColor="@color/white"
                    android:textSize="42sp"
                    android:textStyle="bold" />
                    
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">
                    
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SPENT THIS MONTH" android:textSize="10sp" android:textColor="#94A3B8" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvPersonal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹ 0" android:textColor="#FDA4AF" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    
                    <TextView
                        android:id="@+id/tvLangToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/bg_bot_bubble_pro"
                        android:backgroundTint="#ffffff"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="தமிழ்"
                        android:textColor="@color/primary_indigo"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:title="PocketCFO AI" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- 2. SCROLLING CHAT AREA -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/chatScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="200dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/chatLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:orientation="vertical"
            android:padding="16dp" />
    </androidx.core.widget.NestedScrollView>

    <!-- 3. BOTTOM INPUT AREA -->
    <LinearLayout
        android:id="@+id/inputControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="24dp"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="32dp">

        <HorizontalScrollView 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:scrollbars="none" 
            android:paddingBottom="12dp">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content">
                <Button android:id="@+id/chipIncome" android:layout_width="wrap_content" android:layout_height="36dp" android:text="+ Income" android:textSize="12sp" android:backgroundTint="@color/bubble_user" android:textColor="@color/primary_indigo" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/chipExpense" android:layout_width="wrap_content" android:layout_height="36dp" android:text="- Expense" android:textSize="12sp" android:backgroundTint="#FEF2F2" android:textColor="@color/loss_red" android:layout_marginEnd="8dp"/>
                <Button android:id="@+id/chipPersonal" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Home Log" android:textSize="12sp" android:backgroundTint="#F0FDF4" android:textColor="@color/profit_green"/>
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout 
            android:layout_width="match_parent" 
            android:layout_height="52dp" 
            android:gravity="center_vertical"
            android:background="@drawable/bg_bot_bubble_pro"
            android:paddingHorizontal="4dp">
            
            <ImageButton 
                android:id="@+id/btnVoice" 
                android:layout_width="44dp" 
                android:layout_height="44dp" 
                android:background="?attr/selectableItemBackgroundBorderless" 
                android:src="@android:drawable/ic_btn_speak_now" 
                app:tint="@color/text_secondary"/>
                
            <EditText 
                android:id="@+id/etInput" 
                android:layout_width="0dp" 
                android:layout_height="match_parent" 
                android:layout_weight="1" 
                android:background="@null" 
                android:hint="Type or Speak..." 
                android:textColorHint="@color/text_secondary"
                android:paddingHorizontal="8dp" 
                android:textColor="@color/text_main" />
                
            <ImageButton 
                android:id="@+id/btnSend" 
                android:layout_width="44dp" 
                android:layout_height="44dp" 
                android:background="@drawable/bg_user_bubble" 
                android:backgroundTint="@color/primary_indigo"
                android:src="@android:drawable/ic_menu_send" 
                app:tint="@color/white"/>
        </LinearLayout>
        
        <!-- We removed the actual bottom nav for a cleaner chat interface, or we can add it later if the user wants tabs. Let's keep it clean for hackathon demo. -->
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
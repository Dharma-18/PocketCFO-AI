<?xml version="1.0" encoding="utf-8"?>
<!-- Rich transaction receipt card — used in chat log for each logged transaction -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="260dp"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Colored header bar (green=income / red=expense) -->
        <View
            android:id="@+id/cardAccentBar"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:background="#22C55E"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <!-- Transaction type icon -->
            <TextView
                android:id="@+id/tvCardIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_stat_green"
                android:gravity="center"
                android:text="💵"
                android:textSize="20sp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCardDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cash Sale"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvCardTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:30 PM"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Amount -->
            <TextView
                android:id="@+id/tvCardAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+₹500"
                android:textColor="#16A34A"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" android:layout_marginStart="14dp" android:layout_marginEnd="14dp"/>

        <!-- Source + Category chips row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvCardSource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💵 Cash"
                android:textColor="#0369A1"
                android:textSize="10sp"
                android:background="@drawable/bg_stat_blue"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvCardCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Business"
                android:textColor="#0D9488"
                android:textSize="10sp"
                android:background="@drawable/bg_stat_teal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"/>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvCardType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INCOME"
                android:textColor="#16A34A"
                android:textSize="9sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
